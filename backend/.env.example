# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real

# Django
DEBUG=False
SECRET_KEY=gere-uma-chave-forte-com-python-secrets.token_urlsafe-50
ALLOWED_HOSTS=seu-dominio.dokku.com,localhost

# Banco de dados
DB_NAME=bolao
DB_USER=bolao_user
DB_PASSWORD=senha-forte-aqui
DB_HOST=db
DB_PORT=5432

# CORS — domínio do frontend
CORS_ALLOWED_ORIGINS=https://frontend.seu-dominio.com

# Football Data API
FOOTBALL_API_KEY=sua_chave_aqui

# Redis (Celery broker)
# Em desenvolvimento: redis://redis:6379/0  (nome do serviço do compose)
# Em produção Dokku: preenchido automaticamente ao linkar o plugin redis
REDIS_URL=redis://redis:6379/0
